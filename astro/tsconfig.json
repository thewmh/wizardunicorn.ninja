{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    // astro check doesn't properly recognize client:* directives on <script> tags in .astro component files.
    // The actual Astro compiler handles these correctly at build time. Suppress to allow builds to pass.
    "noUnusedLocals": false,
    "noUnusedParameters": false
  }
}
