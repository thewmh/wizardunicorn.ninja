---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import NoteCard from '../components/NoteCard.astro';
import { getCollection } from 'astro:content';

const essays = await getCollection('essays');
const sortedEssays = essays
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const notes = await getCollection('notes');
const sortedNotes = notes
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) => date.toLocaleDateString('en-US', { 
  year: 'numeric', month: 'short', day: 'numeric' 
});
---

<BaseLayout title="Wizard Unicorn Ninja" description="A personal knowledge base and hobby space — a living collection of things I've learned, built, and care about." pageType="website">
  <div class="max-w-[65ch] mx-auto px-4 py-12">
    <!-- Hero -->
    <section class="mb-16">
      <h1 class="font-heading font-bold text-[2.75rem] text-[var(--text)] mb-4">
        👋 I'm William Harrison
      </h1>
      <p class="text-[var(--text)] text-lg" style="line-height: 1.7;">
        I build things on the internet. I write about design systems, developer roadmaps,
        and occasionally about things that don't matter. I also have opinions about class names.
      </p>
    </section>

    <!-- Recent Essays -->
    <section class="mb-16">
      <h2 class="font-heading font-bold text-xl text-[var(--text)] mb-6">Recent Essays</h2>
      {sortedEssays.length > 0 ? (
        <div class="flex flex-col gap-4">
          {sortedEssays.map(essay => (
            <EssayCard
              title={essay.data.title}
              description={essay.data.description}
              date={formatDate(essay.data.date)}
              tags={essay.data.tags}
              href={`/essays/${essay.slug}/`}
            />
          ))}
        </div>
      ) : (
        <p class="text-[var(--text-muted)]">No essays yet.</p>
      )}
    </section>

    <!-- Recent Notes -->
    <section class="mb-16">
      <h2 class="font-heading font-bold text-xl text-[var(--text)] mb-6">Recent Notes</h2>
      {sortedNotes.length > 0 ? (
        <div class="flex flex-col gap-4">
          {sortedNotes.map(note => (
            <NoteCard
              title={note.data.title}
              description={note.data.description}
              date={formatDate(note.data.date)}
              tags={note.data.tags}
              noteType={note.data.noteType}
              href={`/notes/${note.slug}/`}
            />
          ))}
        </div>
      ) : (
        <p class="text-[var(--text-muted)]">No notes yet.</p>
      )}
    </section>

    <!-- About Teaser -->
    <section>
      <h2 class="font-heading font-bold text-xl text-[var(--text)] mb-4">About</h2>
      <div class="card">
        <p class="text-sm text-[var(--text-muted)]" style="line-height: 1.7;">
          This is my personal knowledge base — a garden with both cultivated essays and wild notes.
        </p>
        <nav class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-xs" aria-label="About subsections">
          <a href="/about/" class="text-[var(--accent)] hover:text-[var(--accent-hover)] no-underline transition-colors duration-150">About</a>
          <span class="text-[var(--text-muted)]" aria-hidden="true">&middot;</span>
          <a href="/about/books/" class="text-[var(--accent)] hover:text-[var(--accent-hover)] no-underline transition-colors duration-150">Books</a>
          <span class="text-[var(--text-muted)]" aria-hidden="true">&middot;</span>
          <a href="/about/hobbies/" class="text-[var(--accent)] hover:text-[var(--accent-hover)] no-underline transition-colors duration-150">Hobbies</a>
          <span class="text-[var(--text-muted)]" aria-hidden="true">&middot;</span>
          <a href="/about/setup/" class="text-[var(--accent)] hover:text-[var(--accent-hover)] no-underline transition-colors duration-150">Setup</a>
          <span class="text-[var(--text-muted)]" aria-hidden="true">&middot;</span>
          <a href="/about/resources/" class="text-[var(--accent)] hover:text-[var(--accent-hover)] no-underline transition-colors duration-150">Resources</a>
          <span class="text-[var(--text-muted)]" aria-hidden="true">&middot;</span>
          <a href="/about/fitness/" class="text-[var(--accent)] hover:text-[var(--accent-hover)] no-underline transition-colors duration-150">Fitness</a>
        </nav>
      </div>
    </section>
  </div>
</BaseLayout>
