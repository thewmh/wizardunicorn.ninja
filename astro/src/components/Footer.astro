---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)] bg-[var(--bg)] transition-colors duration-300 mt-12">
  <div class="max-w-[65ch] mx-auto px-4 py-6 text-center">
    <p class="text-sm text-[var(--text-muted)] m-0">
      &copy; {year} William Harrison. Built with Astro.
    </p>
  </div>
</footer>
