---
import { nav } from "../config/navigation";
import ThemeSwitcher from "./ThemeSwitcher.tsx";
---

<header class="border-b border-[var(--border)] bg-[var(--bg)] transition-colors duration-300">
  <div class="max-w-[65ch] mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-heading font-bold text-lg text-[var(--text)] no-underline hover:text-[var(--accent)] transition-colors duration-150">
      Wizard Unicorn Ninja
    </a>
    <nav class="flex items-center gap-6" aria-label="Main navigation">
      <ul class="flex items-center gap-5 list-none m-0 p-0">
        {nav.map(item => (
          <li>
            <a
              href={item.href}
              class="text-[var(--text-muted)] no-underline text-sm hover:text-[var(--text)] transition-colors duration-150"
            >
              {item.text}
            </a>
          </li>
        ))}
      </ul>
      <ThemeSwitcher client:load />
    </nav>
  </div>
</header>
