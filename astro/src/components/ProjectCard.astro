---
/**
 * ProjectCard — Card for project listings
 */
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  tags?: string[];
  liveUrl?: string;
  repoUrl?: string;
  href: string;
}

const { title, description, date, tags = [], liveUrl, repoUrl, href } = Astro.props;
---

<article class="card no-underline">
  <h3 class="font-heading font-semibold text-[var(--text)] m-0 mb-2">
    <a href={href} class="no-underline text-[var(--text)] hover:text-[var(--accent)] transition-colors duration-150">
      {title}
    </a>
    {(liveUrl || repoUrl) && (
      <span class="inline-flex ml-2 align-middle">
        {liveUrl && (
          <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--accent)] text-xs ml-1 no-underline" aria-label="Live demo">
            &nearr;
          </a>
        )}
        {repoUrl && (
          <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--accent)] text-xs ml-1 no-underline" aria-label="Source code">
            &lt;/&gt;
          </a>
        )}
      </span>
    )}
  </h3>
  <p class="text-sm text-[var(--text-muted)] m-0 mb-3" style="line-height: 1.7;">
    {description}
  </p>
  <div class="flex items-center gap-2 flex-wrap">
    <time class="text-xs text-[var(--text-muted)]">{date}</time>
    {tags.length > 0 && (
      <>
        <span class="text-[var(--text-muted)] text-xs">&middot;</span>
        {tags.map(tag => (
          <Tag label={tag} />
        ))}
      </>
    )}
  </div>
</article>
