---
/**
 * NoteCard — Card for note listings
 */
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  tags?: string[];
  noteType?: string;
  href: string;
}

const { title, description, date, tags = [], noteType, href } = Astro.props;
---

<article class="card no-underline">
  {noteType
    ? <span class="text-xs text-[var(--text-muted)] uppercase tracking-wide">{noteType}</span>
    : null
  }
  <h3 class="font-heading font-semibold text-[var(--text)] m-0 mb-2 mt-1">
    <a href={href} class="no-underline text-[var(--text)] hover:text-[var(--accent)] transition-colors duration-150">
      {title}
    </a>
  </h3>
  <p class="text-sm text-[var(--text-muted)] m-0 mb-3" style="line-height: 1.7;">
    {description}
  </p>
  <div class="flex items-center gap-2 flex-wrap">
    <time class="text-xs text-[var(--text-muted)]">{date}</time>
    {tags.length > 0 && (
      <>
        <span class="text-[var(--text-muted)] text-xs">&middot;</span>
        {tags.map(tag => (
          <Tag label={tag} />
        ))}
      </>
    )}
  </div>
</article>
